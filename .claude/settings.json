{
  "enabledPlugins": {
    "frontend-design@claude-code-marketplace": true,
    "webapp-testing@claude-code-marketplace": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "command": "code-review-graph update --skip-flows",
        "timeout": 5000
      }
    ],
    "SessionStart": [
      {
        "command": "code-review-graph status",
        "timeout": 3000
      }
    ],
    "PreCommit": [
      {
        "command": "code-review-graph detect-changes --brief",
        "timeout": 10000
      }
    ]
  }
}
